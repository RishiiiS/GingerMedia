{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": [
    "eslint:recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "script"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": "warn",
    "quotes": ["error", "single"],
    "semi": ["error", "always"]
  }
}
